# =============================================================================
# Psyche v2 — .gitignore
# =============================================================================

# --- Secrets (NEVER commit these) ---
.env

# --- Local SQLite database files ---
*.db
*.sqlite
*.sqlite3

# --- Python cache & build artifacts ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- IDE / editor files ---
.vscode/
.idea/
*.suo
*.user

# --- OS files ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log
